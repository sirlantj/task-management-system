# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=taskmanagement
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# ADO.NET Connection String (Npgsql format)
CONNECTION_STRING=Host=localhost;Port=5433;Database=taskmanagement;Username=postgres;Password=changeme

# JWT Configuration
JWT_SECRET=replace-with-a-strong-random-secret-key-at-least-32-chars
JWT_ISSUER=TaskManagementSystem
JWT_AUDIENCE=TaskManagementSystem
JWT_EXPIRES_MINUTES=60

# Demo Credentials (seeded in init.sql)
# Email: demo@taskmanagement.local
# Password: Demo@12345
